        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"externalId\": \"{{ $('📊 Extrair Dados da Decisão').item.json.externalId }}\",\n  \"document\": \"{{ $('📊 Extrair Dados da Decisão').item.json.document }}\",\n  \"reportId\": \"{{ $('📊 Extrair Dados da Decisão').item.json.reportId }}\",\n  \"creditStatus\": \"APROVADO\",\n  \"score\": {{ $('📊 Extrair Dados da Decisão').item.json.score }},\n  \"action\": \"MOVE_TO_PROPOSAL\",\n  \"notes\": \"Análise GYRA+ aprovada automaticamente. Score: {{ $('📊 Extrair Dados da Decisão').item.json.score }}/1000\"\n}",
        "options": {
